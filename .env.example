GROQ_API_KEY="your_groq_api_key_here"
WEATHER_API_KEY="your_weather_api_key_here"
NEWS_API_KEY="your_news_api_key_here"
SPOTIFY_CLIENT_ID="your_spotify_client_id_here"
SPOTIFY_CLIENT_SECRET="your_spotify_client_secret_here"
SPOTIFY_REDIRECT_URI=your_callback_url_here
DEFAULT_CITY=your_city
FACE_AUTH_ENABLED=true_or_false
# Path to your Piper TTS voice model (.onnx file).
# Download en_GB-alan-medium.onnx + en_GB-alan-medium.onnx.json (~60 MB) from:
#   https://huggingface.co/rhasspy/piper-voices/tree/main/en/en_GB/alan/medium
# Place both files in the ./voices/ directory, then set this to:
PIPER_MODEL=voices/en_GB-alan-medium.onnx